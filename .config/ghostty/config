# --- Appearance & Font ---
theme = "Atom One Dark"
window-show-tab-bar = always
window-theme = dark
split-divider-color = "#44ff44"
unfocused-split-opacity = 0.7

#font-family = "Whatever Nerd Font Mono"
font-size = 16
font-feature = "liga"
font-feature = "dlig"
#cursor-style = block
cursor-style-blink = true

# --- Shell & Terminal ---
shell-integration = fish
command = /bin/fish

# --- Selection ---
copy-on-select = clipboard

# --- Windows (Meta + Arrows) ---
keybind = ctrl+a>shift+backslash=new_split:right
keybind = ctrl+a>minus=new_split:down

# --- Navigation (Meta + Arrows) ---
keybind = alt+left=goto_split:left
keybind = alt+right=goto_split:right
keybind = alt+up=goto_split:up
keybind = alt+down=goto_split:down

# --- Tabs (Shift + Arrows) ---
keybind = shift+down=new_tab
keybind = shift+left=previous_tab
keybind = shift+right=next_tab

# --- System ---
keybind = ctrl+a>r=reload_config

# --- Macos ---
macos-option-as-alt = left
macos-titlebar-style = transparent

